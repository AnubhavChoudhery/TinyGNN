# ─── Default: normalize to LF in repo ───────────────────────────────────────
* text=auto eol=lf

# Shell scripts: force LF (must be Unix line endings for WSL/Linux execution)
*.sh text eol=lf

# C++ source: LF
*.cpp text eol=lf
*.hpp text eol=lf
*.h   text eol=lf

# Build files: LF
CMakeLists.txt text eol=lf
Makefile       text eol=lf

# Docs/config: LF
*.md         text eol=lf
*.txt        text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Binary build artifacts: don't touch line endings
*.exe  binary
*.o    binary
*.a    binary
*.so   binary
*.dll  binary
